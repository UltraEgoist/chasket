{
  "name": "chasket-lang",
  "displayName": "Chasket",
  "description": "%extension.description%",
  "version": "0.2.2",
  "publisher": "chasket",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "chasket",
    "web components",
    "custom elements",
    "template",
    "compiler",
    "shadow dom"
  ],
  "icon": "icons/chasket-icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UltraEgoist/chasket"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:chasket"
  ],
  "contributes": {
    "languages": [
      {
        "id": "chasket",
        "aliases": [
          "Chasket",
          "chasket"
        ],
        "extensions": [
          ".csk"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/chasket-file-light.svg",
          "dark": "./icons/chasket-file-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "chasket",
        "scopeName": "source.csk",
        "path": "./syntaxes/chasket.tmLanguage.json",
        "embeddedLanguages": {
          "source.css": "css",
          "text.html.basic": "html",
          "source.js": "javascript",
          "meta.block.template.csk": "html",
          "meta.block.style.csk": "css"
        }
      }
    ],
    "configuration": {
      "title": "Chasket",
      "properties": {
        "chasket.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "%config.enableDiagnostics.description%"
        },
        "chasket.compilerPath": {
          "type": "string",
          "default": "",
          "description": "%config.compilerPath.description%"
        }
      }
    }
  }
}
