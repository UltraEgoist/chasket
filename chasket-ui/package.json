{
  "name": "@chasket/chasket-ui",
  "version": "0.2.2",
  "description": "Official UI component library for Chasket — pre-built, accessible Web Components",
  "main": "dist/chasket-ui.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/chasket-ui.js",
      "types": "./index.d.ts"
    },
    "./components/*": "./dist/*.js"
  },
  "sideEffects": true,
  "files": [
    "dist/",
    "index.d.ts"
  ],
  "keywords": [
    "chasket",
    "ui",
    "components",
    "web-components",
    "design-system",
    "accessible",
    "shadow-dom"
  ],
  "author": "Aspect",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UltraEgoist/chasket.git",
    "directory": "chasket-ui"
  },
  "homepage": "https://github.com/UltraEgoist/chasket#readme",
  "bugs": {
    "url": "https://github.com/UltraEgoist/chasket/issues"
  },
  "peerDependencies": {
    "@chasket/chasket": ">=0.1.0"
  },
  "scripts": {
    "build": "node build.js",
    "test": "node --test test/components.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
